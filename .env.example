# Copy this file to .env and fill in the values for local development
# Never commit .env to git!

# Django settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (leave empty to use local SQLite)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Cloudinary media storage (optional for local development)
# Set USE_CLOUDINARY=True and fill in credentials to use Cloudinary
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional Render convenience variable (Render sets this automatically)
# RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com

# For production on Render Blueprint (DATABASE_URL comes from fromDatabase in render.yaml)
# Render creates SECRET_KEY automatically via generateValue.
# You must provide the Cloudinary credentials when creating the Blueprint.
# Core variables expected in production:
#   SECRET_KEY        - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   DEBUG             - False
#   ALLOWED_HOSTS     - 127.0.0.1,localhost (Render hostname is auto-added by settings)
#   CSRF_TRUSTED_ORIGINS - http://127.0.0.1,http://localhost (Render hostname is auto-added)
#   USE_CLOUDINARY    - True
#   CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
#   DB_SSL_REQUIRE    - True (for Render PostgreSQL)
